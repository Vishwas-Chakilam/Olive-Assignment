# Copy to repo root .env (recommended) or backend/.env — both are gitignored.

# --- Local development (MySQL) ---
# Create DB: mysql -u root -p < backend/db/init_mysql.sql
DATABASE_URL=mysql+aiomysql://root:YOUR_MYSQL_PASSWORD@localhost:3306/ollive

# --- Docker Compose uses PostgreSQL instead ---
# DATABASE_URL=postgresql+asyncpg://ollive:ollive@localhost:5432/ollive

INGESTION_URL=http://localhost:8000/logs

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

DEFAULT_PROVIDER=mock
DEFAULT_MODEL=mock-gpt
JWT_SECRET=change-me-to-a-long-random-secret-key

# Optional: SQLite fallback (no MySQL/Postgres server)
# DATABASE_URL=sqlite+aiosqlite:///./backend/data/ollive.db
